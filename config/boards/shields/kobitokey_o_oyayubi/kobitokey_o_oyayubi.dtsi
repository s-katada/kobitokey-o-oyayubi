/*
 * kobitokey-o-oyayubi shield (shared devicetree)
 *
 * Hardware: each half has a Seeed XIAO nRF52840 mounted on the thumb-unit PCB.
 * 4 rows x 5 cols main matrix, plus a PMW3610 optical trackball wired in
 * 3-wire SPI (SDIO shares MOSI/MISO).
 *
 * Pin mapping is identical on both halves (extracted from the KiCad netlist
 * in pcb/thumb-unit-{left,right}.kicad_pcb):
 *
 *   ROW0 = P0.29 (XIAO D3)
 *   ROW1 = P0.04 (XIAO D4)
 *   ROW2 = P0.05 (XIAO D5)
 *   ROW3 = P1.11 (XIAO D6)        // thumb row
 *   COL0 = P1.12 (XIAO D7)        // innermost (index-finger side)
 *   COL1 = P1.13 (XIAO D8)
 *   COL2 = P1.14 (XIAO D9)
 *   COL3 = P1.15 (XIAO D10)
 *   COL4 = P0.10 (NFC2 back pad)  // outermost (pinky side); only on rows 0-2
 *
 *   Trackball SDIO  = P0.02 (XIAO D0)
 *   Trackball SCLK  = P0.03 (XIAO D1)
 *   Trackball MOTION= P0.28 (XIAO D2)
 *   Trackball NCS   = P0.09 (NFC1 back pad)
 *
 * Diode orientation (both halves): anode on ROW, cathode toward switch and
 * then COL. That makes the conduction direction row -> col, so we need
 * `diode-direction = "row2col"`. ROWs are scan outputs, COLs are inputs
 * with pull-down.
 *
 * Physical column order:
 *   - LEFT half PCB places COL0 at X=198 (innermost) and COL4 at X=134
 *     (pinky). To match the natural QWERTY reading order in the unified
 *     4x10 keymap, the left overlay declares col-gpios in REVERSE order
 *     so that kscan column 0 corresponds to the physical pinky.
 *   - RIGHT half PCB places COL0 at X=134 (innermost). The right overlay
 *     uses the natural order so kscan column 0 is the inner index column,
 *     which sits at combined column 5 thanks to col-offset.
 */

#include <dt-bindings/zmk/matrix_transform.h>

/ {
    kscan0: kscan0 {
        compatible = "zmk,kscan-gpio-matrix";
        wakeup-source;
        diode-direction = "row2col";

        row-gpios
            = <&xiao_d 3 GPIO_ACTIVE_HIGH>   /* ROW0 - P0.29 */
            , <&xiao_d 4 GPIO_ACTIVE_HIGH>   /* ROW1 - P0.04 */
            , <&xiao_d 5 GPIO_ACTIVE_HIGH>   /* ROW2 - P0.05 */
            , <&xiao_d 6 GPIO_ACTIVE_HIGH>   /* ROW3 - P1.11 */
            ;
        /* col-gpios are defined per-half in the *_left.overlay /
         * *_right.overlay because the two halves need opposite scan-order
         * to land in a coherent unified matrix. */
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        rows = <4>;
        columns = <10>;
        /* Combined matrix layout (after each half's col-offset is applied):
         *   cols 0..4  = LEFT half  (pinky -> index, outer to inner)
         *   cols 5..9  = RIGHT half (index -> pinky, inner to outer)
         *   (3,0) and (3,9) have no physical switch (no pinky thumb key). */
        map = <
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)   RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)   RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9)
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)   RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9)
RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4)   RC(3,5) RC(3,6) RC(3,7) RC(3,8) RC(3,9)
        >;
    };

    /* Right-half trackball is relayed from peripheral to central over split BLE. */
    split_inputs {
        #address-cells = <1>;
        #size-cells = <0>;

        tb_right_split: tb_right_split@0 {
            compatible = "zmk,input-split";
            reg = <0>;
        };
    };

    /* Listeners live in the shared file but only get enabled on the central side. */
    tb_left_listener: tb_left_listener {
        compatible = "zmk,input-listener";
        status = "disabled";
    };

    tb_right_listener: tb_right_listener {
        compatible = "zmk,input-listener";
        status = "disabled";
        device = <&tb_right_split>;
    };

    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        kscan = <&kscan0>;
        transform = <&default_transform>;
    };

    chosen {
        zmk,kscan = &kscan0;
        zmk,physical-layout = &physical_layout0;
    };
};
