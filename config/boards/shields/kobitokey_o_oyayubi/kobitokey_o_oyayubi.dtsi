/*
 * kobitokey-o-oyayubi shield (shared devicetree)
 *
 * Per half: Seeed XIAO nRF52840, 4x5 matrix, PMW3610 trackball (3-wire SPI).
 *
 * Pin mapping (both halves, from firmware/keyboard.toml @ 4a4ee09):
 *   D0  (P0_02) -> SDIO   (trackball, bidirectional data)
 *   D1  (P0_03) -> SCLK   (trackball clock)
 *   D2  (P0_28) -> MOTION (trackball IRQ, active low)
 *   D3  (P0_29) -> ROW0
 *   D4  (P0_04) -> ROW1
 *   D5  (P0_05) -> ROW2
 *   D6  (P1_11) -> ROW3
 *   D7  (P1_12) -> COL3
 *   D8  (P1_13) -> COL2
 *   D9  (P1_14) -> COL1
 *   D10 (P1_15) -> COL0
 *   NFC1 (P0_09) back pad -> NCS (trackball chip-select)
 *   NFC2 (P0_10) back pad -> COL4
 */

#include <dt-bindings/zmk/matrix_transform.h>

/ {
    kscan0: kscan0 {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";
        wakeup-source;

        row-gpios
            = <&xiao_d 3 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 4 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 5 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 6 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            ;
        col-gpios
            = <&xiao_d 10 GPIO_ACTIVE_HIGH>
            , <&xiao_d 9  GPIO_ACTIVE_HIGH>
            , <&xiao_d 8  GPIO_ACTIVE_HIGH>
            , <&xiao_d 7  GPIO_ACTIVE_HIGH>
            , <&gpio0 10  GPIO_ACTIVE_HIGH>
            ;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        rows = <4>;
        columns = <10>;
        map = <
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)   RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)   RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9)
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)   RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9)
RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4)   RC(3,5) RC(3,6) RC(3,7) RC(3,8) RC(3,9)
        >;
    };

    /* Right-half trackball is relayed from peripheral to central over split BLE. */
    split_inputs {
        #address-cells = <1>;
        #size-cells = <0>;

        tb_right_split: tb_right_split@0 {
            compatible = "zmk,input-split";
            reg = <0>;
        };
    };

    /* Listeners live in the shared file but only get enabled on the central side. */
    tb_left_listener: tb_left_listener {
        compatible = "zmk,input-listener";
        status = "disabled";
    };

    tb_right_listener: tb_right_listener {
        compatible = "zmk,input-listener";
        status = "disabled";
        device = <&tb_right_split>;
    };

    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        kscan = <&kscan0>;
        transform = <&default_transform>;
    };

    chosen {
        zmk,kscan = &kscan0;
        zmk,physical-layout = &physical_layout0;
    };
};
