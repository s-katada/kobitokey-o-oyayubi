/*
 * kobitokey-o-oyayubi shield
 *
 * Hardware (per half): Seeed XIAO nRF52840 on the thumb unit, 4x5 matrix, and
 * a PMW3610 optical trackball in 3-wire SPI mode (SDIO shares MOSI/MISO).
 *
 * XIAO pin mapping (identical for left and right halves):
 *   D0  (P0_02) -> SDIO   (trackball, bidirectional data)
 *   D1  (P0_03) -> SCLK   (trackball clock)
 *   D2  (P0_28) -> MOTION (trackball IRQ, active low)
 *   D3  (P0_29) -> ROW0
 *   D4  (P0_04) -> ROW1
 *   D5  (P0_05) -> ROW2
 *   D6  (P1_11) -> ROW3
 *   D7  (P1_12) -> COL3
 *   D8  (P1_13) -> COL2
 *   D9  (P1_14) -> COL1
 *   D10 (P1_15) -> COL0
 *   NFC1 (P0_09) back pad -> NCS (trackball chip-select)
 *   NFC2 (P0_10) back pad -> COL4
 */

#include <dt-bindings/zmk/matrix_transform.h>
#include <dt-bindings/zmk/keys.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,physical-layout = &default_layout;
    };

    default_transform: keymap_transform {
        compatible = "zmk,matrix-transform";
        columns = <10>;
        rows = <4>;
// Left half (cols 0..4)                    | Right half (cols 5..9, mirrored on the PCB)
//  SW0  SW1  SW2  SW3  SW4                 |  SW4  SW3  SW2  SW1  SW0
//  SW5  SW6  SW7  SW8  SW9                 |  SW9  SW8  SW7  SW6  SW5
//  SW10 SW11 SW12 SW13 SW14                |  SW14 SW13 SW12 SW11 SW10
//  SW15 SW16 SW17 SW18 (none)               | (none) SW18 SW17 SW16 SW15
        map = <
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)  RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)  RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9)
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)  RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9)
RC(3,0) RC(3,1) RC(3,2) RC(3,3)          RC(3,6) RC(3,7) RC(3,8) RC(3,9)
        >;
    };

    default_layout: physical_layout {
        compatible = "zmk,physical-layout";
        display-name = "kobitokey-o-oyayubi";
        transform = <&default_transform>;
        kscan = <&kscan0>;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        wakeup-source;

        diode-direction = "col2row";
        row-gpios
            = <&xiao_d 3 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 4 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 5 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 6 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            ;
        col-gpios
            = <&xiao_d 10 GPIO_ACTIVE_HIGH>  /* COL0 -> P1_15 */
            , <&xiao_d 9  GPIO_ACTIVE_HIGH>  /* COL1 -> P1_14 */
            , <&xiao_d 8  GPIO_ACTIVE_HIGH>  /* COL2 -> P1_13 */
            , <&xiao_d 7  GPIO_ACTIVE_HIGH>  /* COL3 -> P1_12 */
            , <&gpio0 10  GPIO_ACTIVE_HIGH>  /* COL4 -> P0_10 (NFC2 back pad) */
            ;
    };

    trackball_listener: trackball_listener {
        compatible = "zmk,input-listener";
        device = <&trackball>;
    };
};

&pinctrl {
    spi0_default: spi0_default {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 3)>,
                    <NRF_PSEL(SPIM_MOSI, 0, 2)>,
                    <NRF_PSEL(SPIM_MISO, 0, 2)>;
        };
    };

    spi0_sleep: spi0_sleep {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 3)>,
                    <NRF_PSEL(SPIM_MOSI, 0, 2)>,
                    <NRF_PSEL(SPIM_MISO, 0, 2)>;
            low-power-enable;
        };
    };
};

&spi0 {
    status = "okay";
    compatible = "nordic,nrf-spim";
    pinctrl-0 = <&spi0_default>;
    pinctrl-1 = <&spi0_sleep>;
    pinctrl-names = "default", "sleep";
    cs-gpios = <&gpio0 9 GPIO_ACTIVE_LOW>;

    trackball: trackball@0 {
        status = "okay";
        compatible = "pixart,pmw3610-alt";
        reg = <0>;
        spi-max-frequency = <2000000>;
        irq-gpios = <&gpio0 28 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        cpi = <800>;
        evt-type = <INPUT_EV_REL>;
        x-input-code = <INPUT_REL_X>;
        y-input-code = <INPUT_REL_Y>;
    };
};
